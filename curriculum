header {
    position: relative;
    padding-bottom: 30px;
    min-height: 220px;
}

.foto {
    position: absolute;
    top: 0;
    right: 0;
    width: 160px;
    height: 200px;
    object-fit: cover;
    border-radius: 12px;
    box-shadow: 0 4px 10px rgba(0,0,0,0.2);
}
